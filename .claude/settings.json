{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "permissions": {
    "deny": [
      "Read(config.env)",
      "Read(**/config.env)",
      "Read(**/*.env)",
      "Read(**/.env)",
      "Read(**/*.pem)",
      "Read(**/*.key)",

      "Bash(cat config.env*)",
      "Bash(cat ./config.env*)",
      "Bash(bat config.env*)",
      "Bash(bat ./config.env*)",
      "Bash(less config.env*)",
      "Bash(less ./config.env*)",
      "Bash(more config.env*)",
      "Bash(more ./config.env*)",
      "Bash(head config.env*)",
      "Bash(head ./config.env*)",
      "Bash(tail config.env*)",
      "Bash(tail ./config.env*)",
      "Bash(tac config.env*)",
      "Bash(tac ./config.env*)",
      "Bash(nl config.env*)",
      "Bash(nl ./config.env*)",
      "Bash(xxd config.env*)",
      "Bash(xxd ./config.env*)",
      "Bash(od config.env*)",
      "Bash(od ./config.env*)",
      "Bash(hexdump config.env*)",
      "Bash(hexdump ./config.env*)",
      "Bash(strings config.env*)",
      "Bash(strings ./config.env*)",
      "Bash(base64 config.env*)",
      "Bash(base64 ./config.env*)",
      "Bash(rev config.env*)",
      "Bash(rev ./config.env*)",
      "Bash(cp config.env*)",
      "Bash(cp ./config.env*)",
      "Bash(mv config.env*)",
      "Bash(mv ./config.env*)",
      "Bash(dd if=config.env*)",
      "Bash(dd if=./config.env*)",
      "Bash(view config.env*)",
      "Bash(view ./config.env*)",
      "Bash(vi config.env*)",
      "Bash(vi ./config.env*)",
      "Bash(vim config.env*)",
      "Bash(vim ./config.env*)",
      "Bash(nano config.env*)",
      "Bash(nano ./config.env*)",
      "Bash(source config.env*)",
      "Bash(source ./config.env*)",
      "Bash(. config.env*)",
      "Bash(. ./config.env*)"
    ]
  }
}
