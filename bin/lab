#!/usr/bin/env bash
# bin/lab — set up and inspect the lab.
#
#   lab init [--rotate-token]   # config.env, LAB_TOKEN, notebook repo, dirs, clone target, reconcile
#   lab status                  # config + dependency + queue summary
#
# NB: no stdin prompts. Ever.

set -euo pipefail
# shellcheck source=../lib/common.sh
. "$(dirname "$0")/../lib/common.sh"

usage() { echo "usage: lab init|status ..." >&2; exit 2; }

_placeholder_repo() {
  case "${REPO_SLUG:-}" in
    ""|you/*|*/your-sandbox-repo|owner/name) return 0 ;;
    *) return 1 ;;
  esac
}

cmd_init() {
  local rotate=0
  while [ $# -gt 0 ]; do
    case "$1" in --rotate-token) rotate=1; shift ;; *) die "lab init: unknown arg '$1'" ;; esac
  done

  # config.env
  if [ ! -f "$LAB_ROOT/config.env" ]; then
    cp "$LAB_ROOT/config.env.example" "$LAB_ROOT/config.env"
    echo "created config.env from example — edit REPO_SLUG before real work"
  fi

  # LAB_TOKEN
  if [ "$rotate" = 1 ] || [ -z "${LAB_TOKEN:-}" ]; then
    local tok; tok="$(rand_hex 24)"
    env_set "$LAB_ROOT/config.env" LAB_TOKEN "$tok"
    LAB_TOKEN="$tok"
    echo "set LAB_TOKEN (48 hex chars) in config.env"
  fi

  # notebook repo
  if [ ! -d "$NOTEBOOK/.git" ]; then
    mkdir -p "$NOTEBOOK"
    git -C "$NOTEBOOK" init -q
    git -C "$NOTEBOOK" config user.email "lab@local"
    git -C "$NOTEBOOK" config user.name "lab notebook"
    echo "initialized notebook/ git repo"
  fi

  # dirs
  mkdir -p "$DOCKET"/{open,claimed,blocked,done,abandoned} \
           "$WHITEBOARD"/{questions,answered,inbox} \
           "$WORKTREES" "$DOTLAB"

  # Resolve the lab's own GitHub identity and working fork, then clone the FORK.
  if [ -z "${LAB_GH_USER:-}" ] || [ -z "${LAB_GH_TOKEN:-}" ]; then
    warn "LAB_GH_USER / LAB_GH_TOKEN not set. The lab needs its OWN GitHub account."
    warn "Create the account + a PAT (scopes: repo, workflow), set LAB_GH_USER/LAB_GH_TOKEN/LAB_GH_EMAIL in config.env, then re-run 'bin/lab init'."
  elif _placeholder_repo; then
    warn "REPO_SLUG is a placeholder ('${REPO_SLUG:-unset}'). Set it to the upstream target, then re-run 'bin/lab init'."
  elif ! have gh; then
    warn "gh not found — install the GitHub CLI, then re-run 'bin/lab init'."
  else
    local who; who="$(gh_lab api user -q .login 2>/dev/null || echo '?')"
    [ "$who" = "$LAB_GH_USER" ] || warn "token identity is '$who' but LAB_GH_USER is '$LAB_GH_USER' (mismatch?)"

    if [ "${REPO_SLUG%%/*}" = "$LAB_GH_USER" ]; then
      echo "lab already owns $REPO_SLUG; using it directly as the working repo"
    else
      echo "ensuring fork $WORK_SLUG of $REPO_SLUG ..."
      gh_lab repo fork "$REPO_SLUG" --clone=false >/dev/null 2>&1 || warn "fork step reported an issue (already forked?)"
    fi

    if [ -d "$PROJECT/.git" ]; then
      echo "project/ already present ($(git -C "$PROJECT" remote get-url origin 2>/dev/null))"
    else
      echo "cloning fork $WORK_SLUG into project/ ..."
      git_lab clone "https://github.com/$WORK_SLUG.git" "$PROJECT" || die "clone failed (fork not ready yet, or token invalid?)"
    fi
    git -C "$PROJECT" remote get-url upstream >/dev/null 2>&1 || git -C "$PROJECT" remote add upstream "https://github.com/$REPO_SLUG.git"
    git -C "$PROJECT" config user.name "$LAB_GH_USER"
    git -C "$PROJECT" config user.email "${LAB_GH_EMAIL:-$LAB_GH_USER@users.noreply.github.com}"
    echo "working repo: $WORK_SLUG (fork)   upstream: $REPO_SLUG (never a PR base)"
  fi

  [ -d "$PROJECT/.git" ] && bin_reconcile
  echo "lab init complete."
}

bin_reconcile() { "$LAB_ROOT/bin/wt" reconcile >/dev/null 2>&1 || true; }

_count() { ls "$1"/*.md >/dev/null 2>&1 && ls "$1"/*.md | wc -l | tr -d ' ' || echo 0; }

cmd_status() {
  echo "lab status"
  echo "  root:        $LAB_ROOT"
  echo "  upstream:    ${REPO_SLUG:-<unset>}  (default branch: ${DEFAULT_BRANCH}; never a PR base)"
  echo "  working fork: ${WORK_SLUG:-<unset>}"
  echo "  lab account: ${LAB_GH_USER:-<unset>}   gh token: $([ -n "${LAB_GH_TOKEN:-}" ] && echo set || echo MISSING)"
  echo "  bind:        ${DASH_HOST}:${DASH_PORT}   gate: ${GATE_MODE}   tunnel: ${TUNNEL}"
  echo "  dash token:  $([ -n "${LAB_TOKEN:-}" ] && echo set || echo MISSING)"
  echo
  echo "  dependencies:"
  for c in claude node yarn git gh cloudflared; do
    if have "$c"; then printf '    %-12s %s\n' "$c" "$(command -v "$c")"; else printf '    %-12s (not found)\n' "$c"; fi
  done
  echo
  echo "  repos:"
  echo "    project:   $([ -d "$PROJECT/.git" ] && echo present || echo missing)"
  echo "    notebook:  $([ -d "$NOTEBOOK/.git" ] && echo "present ($(git -C "$NOTEBOOK" rev-list --count HEAD 2>/dev/null || echo 0) entries)" || echo missing)"
  echo
  echo "  docket:"
  for st in open claimed blocked done abandoned; do
    printf '    %-10s %s\n' "$st" "$(_count "$DOCKET/$st")"
  done
  echo "  whiteboard questions open: $(_count "$WHITEBOARD/questions")   inbox pending: $(ls "$WHITEBOARD/inbox"/*.json 2>/dev/null | wc -l | tr -d ' ')"
  echo
  if [ -f "$DOTLAB/serve.pid" ] && kill -0 "$(cat "$DOTLAB/serve.pid")" 2>/dev/null; then
    echo "  serve:       running (pid $(cat "$DOTLAB/serve.pid"))"
  else
    echo "  serve:       stopped"
  fi
  if [ -f "$DOTLAB/tunnel-url" ]; then echo "  tunnel url:  $(cat "$DOTLAB/tunnel-url")"; fi
  return 0
}

[ $# -gt 0 ] || usage
sub=$1; shift
case "$sub" in
  init)   cmd_init "$@" ;;
  status) cmd_status "$@" ;;
  *) usage ;;
esac
