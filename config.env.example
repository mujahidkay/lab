# lab configuration — copy to config.env and edit. config.env is gitignored.

# ---- work target ----------------------------------------------------------
# The UPSTREAM repo, as owner/name. The lab FORKS this into its own account and
# works on the fork; it never opens PRs against this repo. Use a SANDBOX first.
REPO_SLUG=upstream-owner/some-repo
# Default branch (branches fork from origin/<this> on the fork).
DEFAULT_BRANCH=main
# How to install the TARGET repo's dependencies so code stages (build/review/fix)
# can build/lint/test. `bin/wt warm` runs this once in project/ and each code
# worktree shares the result. Leave empty to infer from the lockfile
# (yarn.lock -> yarn install, pnpm-lock.yaml -> pnpm install, package-lock.json -> npm ci).
PROJECT_SETUP_CMD=

# ---- the lab's own GitHub identity ----------------------------------------
# The lab acts as its OWN account, never your personal credentials. Create a
# dedicated GitHub account for the lab, then a Personal Access Token for it:
#   classic PAT with scopes: repo, workflow   (repo is needed for private forks)
# The lab account must also have READ access to any PRIVATE upstream you target
# (so it can fork it). Keep the token secret; config.env is gitignored.
LAB_GH_USER=            # the lab account's login, e.g. my-lab-bot
LAB_GH_TOKEN=           # the PAT for that account
LAB_GH_EMAIL=           # commit author email for the lab (e.g. ID+my-lab-bot@users.noreply.github.com)

# ---- apps / API -----------------------------------------------------------
# The API + apps bind here. Keep 127.0.0.1: the tunnel connects locally and
# nothing is exposed directly on the machine.
DASH_HOST=127.0.0.1
# The dashboard port. Running multiple instances (./labctl init <name>)? Give
# EACH instance a UNIQUE DASH_PORT — each publishes its own dashboard on it.
DASH_PORT=8787
# Single shared bearer token gating every API endpoint. Generated by
# `bin/lab init`; treat it like a password. Rotate with `bin/lab init --rotate-token`.
LAB_TOKEN=

# ---- remote access --------------------------------------------------------
# none | cloudflared
TUNNEL=none
# Optional: a named Cloudflare tunnel for a STABLE hostname (requires prior
# `cloudflared login` + `cloudflared tunnel create`). Empty => quick tunnel
# (ephemeral *.trycloudflare.com URL).
CF_TUNNEL_NAME=

# ---- review gate ----------------------------------------------------------
# solo  = one referee subagent   |   panel = judge + small juror panel
GATE_MODE=solo

# ---- autonomous loop pacing (seconds; never pick exactly 300) -------------
ACTIVE_MIN=60
ACTIVE_MAX=1800
IDLE_MIN=1800
IDLE_MAX=3600
